# TABORDA SYSTEM — variables de entorno (Vite las inyecta en build).
# Copia este archivo a .env para desarrollo local (.env está en .gitignore).
# En producción se configuran en Vercel → Settings → Environment Variables
# y requieren REDEPLOY para aplicarse (son de build-time, no de runtime).

# ── Captura de leads (Supabase) ──────────────────────────────────────
# Proyecto Supabase con la tabla public.leads (esquema: supabase/leads.sql).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Pipeline de automatización (n8n) ─────────────────────────────────
# Webhook que recibe cada lead y dispara la secuencia de emails.
# Configuración completa: docs/n8n-pipeline.md. Opcional: sin esta variable
# el formulario guarda solo en Supabase.
VITE_LEAD_WEBHOOK_URL=https://TU-INSTANCIA-N8N/webhook/lead-reset

# ── Checkout de la Instalación Supervisada (Cohorte) ─────────────────
# Link de la pasarela de pago (Hotmart / Gumroad / Bold / Wompi).
# Al definirla con un link válido, TODOS los botones de compra del sitio
# pasan automáticamente de WhatsApp a la pasarela. Sin ella, los CTA abren
# WhatsApp con mensaje de intención de compra (modo cierre 1:1).
VITE_COHORTE_CHECKOUT_URL=https://TU-LINK-DE-PAGO

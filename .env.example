# TABORDA SYSTEM — variables de entorno (Vite las inyecta en build).
# Copia este archivo a .env para desarrollo local (.env está en .gitignore).
# En producción se configuran en Vercel → Settings → Environment Variables
# y requieren REDEPLOY para aplicarse (son de build-time, no de runtime).

# ── Captura de leads (Supabase) ──────────────────────────────────────
# Proyecto Supabase con la tabla public.leads (esquema: supabase/leads.sql).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Pipeline de automatización (n8n) ─────────────────────────────────
# Webhook que recibe cada lead y dispara la secuencia de emails.
# Configuración completa: docs/n8n-pipeline.md. Opcional: sin esta variable
# el formulario guarda solo en Supabase.
VITE_LEAD_WEBHOOK_URL=https://TU-INSTANCIA-N8N/webhook/lead-reset

# ── Checkout de la Instalación Supervisada (Cohorte) ─────────────────
# Link de la pasarela de pago (Hotmart / Gumroad / Bold / Wompi).
# Al definirla con un link válido, TODOS los botones de compra del sitio
# pasan automáticamente de WhatsApp a la pasarela. Sin ella, los CTA abren
# WhatsApp con mensaje de intención de compra (modo cierre 1:1).
VITE_COHORTE_CHECKOUT_URL=https://TU-LINK-DE-PAGO

# ── Tracking de eventos / CRO (src/lib/track.ts) ─────────────────────
# Colector opcional al que se envían los eventos (Plausible/Umami/n8n/
# webhook propio) vía POST fire-and-forget. Sin esta variable el tracking
# sigue funcionando: loguea cada evento en la consola del navegador.
VITE_ANALYTICS_URL=https://TU-COLECTOR/evento

# ── Widget de estado del ecosistema (SystemStatusWidget.tsx) ─────────
# Endpoint JSON del sistema que devuelve { activeOperators, globalStreak }.
# Debe responder con CORS para tabordasystem.com. Sin esta variable el
# widget vive en modo STANDBY (estructura lista, datos pendientes).
VITE_SYSTEM_STATUS_URL=https://sistema.tabordasystem.com/api/status

# ── Webhook de ventas Hotmart (api/hotmart-webhook.ts) ───────────────
# SIN prefijo VITE_ = solo viven en el servidor (Vercel Functions),
# JAMÁS llegan al navegador. Guía completa: docs/HOTMART_WEBHOOK.md.

# Token que Hotmart envía en el header X-HOTMART-HOTTOK. Se obtiene en
# Hotmart → Herramientas → Webhook al configurar la notificación.
HOTMART_HOTTOK=TU-HOTTOK-DE-HOTMART

# Service role key de Supabase (Settings → API). Necesaria para UPDATE
# sobre `leads` e INSERT en `purchases`. NUNCA usar la anon key aquí
# ni exponer esta key con prefijo VITE_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service...

# Webhook de n8n que envía el email de bienvenida al alumno
# (credenciales + link de agendamiento 1:1).
N8N_SALE_WEBHOOK_URL=https://TU-INSTANCIA-N8N/webhook/hotmart-venta
